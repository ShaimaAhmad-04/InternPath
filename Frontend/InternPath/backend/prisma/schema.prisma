datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js" // generates the prisma client used to query the db
}

model User {
  id          Int     @id @default(autoincrement()) // PK, auto-increment
  firstName   String  @db.VarChar(50)
  lastName    String? @db.VarChar(50)               // ? = nullable
  email       String  @unique @db.VarChar(255)
  password    String  @db.VarChar(255)
  phoneNumber String  @db.VarChar(20)
  role        Int

  student Student? // not a column — lets you access the related Student record in code
  company Company? // not a column — lets you access the related Company record in code
}

model Student {
userId         Int       @id
  user           User      @relation(fields: [userId], references: [id])
  major          String?   // Changed from Int to String
  university     String?   @db.VarChar(100)
  experience     String?   @db.Text        // Use Text instead of VarChar(255) for long bios
  gpa            Decimal?
  graduationYear Int?      // Changed from DateTime to Int (to accept 2026)
  linkedinUrl    String?   @db.VarChar(255)
  githubUrl      String?   @db.VarChar(255)
  certifications String[]  // Changed to an Array of Strings
  cvUrl          String?

  // not columns — navigation helpers to access related records in code
  applications       Application[]
  roadmaps           Roadmap[]
  studentInternships StudentInternship[]
  studentSkills      StudentSkill[]
}

model Company {
  userId      Int     @id       // PK and FK to User.id — no separate ID
  user        User    @relation(fields: [userId], references: [id]) // defines the FK relationship
  name        String  @db.VarChar(120)
  description String?
  industry    String? @db.VarChar(100)
  website     String? @db.VarChar(255)
  verified    Boolean @default(false)

  // not columns — navigation helpers to access related records in code
  internships      Internship[]
  companyLocations CompanyLocation[]
}

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  // not columns — navigation helpers to access related records in code
  internshipSkills InternshipSkill[]
  studentSkills    StudentSkill[]
}

model Internship {
  id                 Int      @id @default(autoincrement())
  companyId          Int      // FK to Company
  company            Company  @relation(fields: [companyId], references: [userId])
  title              String   @db.VarChar(150)
  description        String?  @db.VarChar(200)
  postDate           DateTime @db.Date
  submissionDeadline DateTime @db.Date
  duration           String?  @db.VarChar(50)
  location           Location // enum — must be Remote, In_site, or Hybrid
  isPaid             Boolean
  status             Boolean

  // not columns — navigation helpers to access related records in code
  internshipSkills    InternshipSkill[]
  applications        Application[]
  studentInternships  StudentInternship[]
  internshipLocations InternshipLocation[]
}

// restricts location field to these three values only
enum Location {
  Remote
  In_site
  Hybrid
}

model InternshipSkill {
  internshipId  Int
  skillId       Int
  internship    Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  skill         Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  matchingScore Int?
  date          DateTime?  @db.Date

  @@id([internshipId, skillId]) // composite PK
}

model Application {
  id           Int        @id @default(autoincrement())
  studentId    Int        // FK to Student
  internshipId Int        // FK to Internship
  student      Student    @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  status       Int
}

model Roadmap {
  roadmapId       Int       @id @default(autoincrement())
  studentId       Int       // FK to Student
  student         Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  desiredPosition String?   @db.VarChar(100)
  generatedAt     DateTime?

  nodes RoadmapNode[]
}

model RoadmapNode {
  nodeId     Int
  roadmapId  Int     // FK to Roadmap
  roadmap    Roadmap @relation(fields: [roadmapId], references: [roadmapId], onDelete: Cascade)
  title      String  @db.VarChar(150)
  orderIndex Int     // defines step sequence

  @@id([nodeId, roadmapId]) // composite PK
}

model StudentInternship {
  studentId    Int
  internshipId Int
  student      Student    @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@id([studentId, internshipId]) // composite PK
}

model StudentSkill {
  studentId  Int
  skillId    Int
  student    Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  experience Int?

  @@id([studentId, skillId]) // composite PK
}

model CompanyLocation {
  companyId Int
  city      Int
  country   Int
  street    String? @db.VarChar(50)
  company   Company @relation(fields: [companyId], references: [userId], onDelete: Cascade)

  @@id([companyId, city, country]) // composite PK
}

model InternshipLocation {
  internshipId Int
  city         Int
  country      Int
  street       String?    @db.VarChar(50)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@id([internshipId, city, country]) // composite PK
}
